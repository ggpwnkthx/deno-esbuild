{
  "workspace": [
    "./esbuild",
    "./plugins/deno",
    "./plugins/css",
    "./wrappers/shared",
    "./wrappers/hono",
    "./wrappers/oak"
  ],
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.30",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/semver": "jsr:@std/semver@^1.0.8",
    "esbuild": "file:./esbuild/mod.ts",
    "@ggpwnkthx/esbuild-wrapper-shared": "file:./wrappers/shared/mod.ts"
  },
  "exclude": [
    "./.*"
  ],
  "tasks": {
    "bin:build": "deno run --allow-read --allow-write --allow-run=git,go --allow-env scripts/main.ts",
    "bin:list": "deno run --allow-read scripts/main.ts --list"
  }
}
