{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}",
        "timeout": 1200000,
        "chunkTimeout": 600000
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax-M3"
        }
      }
    }
  },
  "enabled_providers": [
    "minimax"
  ],
  "model": "minimax/MiniMax-M3",
  "share": "disabled",
  "lsp": true,
  "formatter": {
    "deno-fmt": {
      "command": [
        "deno",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".json",
        ".jsonc",
        ".md"
      ]
    }
  },
  "default_agent": "deno-lead",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/*.env": "deny",
      "**/*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.sample": "allow",
      "*.env.template": "allow",
      "**/*.env.example": "allow",
      "**/*.env.sample": "allow",
      "**/*.env.template": "allow",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.pfx": "deny",
      "**/*.pfx": "deny",
      "**/id_rsa": "deny",
      "**/id_ed25519": "deny",
      "**/credentials.json": "deny",
      "**/.npmrc": "deny"
    },
    "edit": {
      "*": "ask",
      "node_modules/**": "deny",
      "dist/**": "deny",
      "build/**": "deny",
      "coverage/**": "deny",
      ".git/**": "deny",
      ".opencode/.cache/**": "deny"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git ls-files*": "allow",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "find *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "deno *": "ask",
      "deno fmt*": "allow",
      "deno lint*": "allow",
      "deno check*": "allow",
      "deno test*": "allow",
      "deno info*": "allow",
      "deno doc*": "allow",
      "deno publish --dry-run*": "allow",
      "deno task*": "ask",
      "deno publish*": "ask",
      "deno run*": "ask",
      "deno compile*": "ask",
      "deno eval*": "deny",
      "deno install*": "deny",
      "npm*": "deny",
      "pnpm*": "deny",
      "yarn*": "deny",
      "npx*": "deny",
      "node*": "deny",
      "bun add*": "deny",
      "bun install*": "deny",
      "bunx*": "deny",
      "python*": "deny",
      "python3*": "deny",
      "py *": "deny",
      "pip*": "deny",
      "pip3*": "deny",
      "pipx*": "deny",
      "uv*": "deny",
      "curl*": "ask",
      "wget*": "ask",
      "rm -rf *": "deny",
      "chmod +x *": "ask",
      "sh -c *": "ask",
      "bash -c *": "ask"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "skill": {
      "*": "deny",
      "opencode-session-discipline": "allow",
      "critical-code-review": "allow",
      "deno-architecture-review": "allow",
      "deno-dependency-policy": "allow",
      "deno-http-boundary-audit": "allow",
      "deno-performance-check": "allow",
      "deno-release-checklist": "allow",
      "deno-test-strategy": "allow",
      "deno-jsr-score-audit": "allow"
    },
    "task": {
      "*": "deny",
      "deno-implementer": "allow",
      "deno-critical-reviewer": "allow",
      "deno-architecture-reviewer": "allow",
      "deno-http-auditor": "allow",
      "deno-performance-auditor": "allow",
      "deno-test-strategist": "allow",
      "deno-release-manager": "allow",
      "deno-jsr-score-auditor": "allow"
    },
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "watcher": {
    "ignore": [
      ".opencode/**",
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "coverage/**"
    ]
  }
}
